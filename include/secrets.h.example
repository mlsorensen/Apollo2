#pragma once

// Copy this file to include/secrets.h and paste your machine's BLE auth token.
// include/secrets.h is gitignored — it holds a per-machine secret.
//
// The token is the cloud-issued `bleAuthToken` (see the La Marzocco cloud /
// pylamarzocco, the QR label inside the machine, or pairing mode). This
// compile-time approach is a dev convenience; a friendlier on-device flow
// comes later.

#define MICRA_BLE_TOKEN   "paste-your-token-here"
// The machine's BLE MAC (from the scan, e.g. the serial log). Temporary until
// it's saved to NVS via the Settings scan.
#define MICRA_BLE_ADDRESS "aa:bb:cc:dd:ee:ff"
